# Copy to .env.local for local dev, or set these in your hosting dashboard.

# Google Analytics 4 measurement id.
# If unset (or empty) the code falls back to the id baked into lib/analytics.ts.
NEXT_PUBLIC_GA_ID=

# Demo walkthrough video on /enterprise-tryon.
# Paste a normal YouTube or Vimeo share link — the component converts it to an
# embed URL itself. Leave empty to keep the "coming soon" poster.
# Examples:
#   https://www.youtube.com/watch?v=XXXXXXXXXXX
#   https://youtu.be/XXXXXXXXXXX
#   https://vimeo.com/123456789
NEXT_PUBLIC_DEMO_VIDEO_URL=
